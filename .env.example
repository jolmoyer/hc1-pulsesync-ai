# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_SECRET_KEY=change-me-to-a-long-random-string-in-production
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pulsesync:pulsesync@localhost:5432/pulsesync
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis (background workers) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-different-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PHI Encryption ────────────────────────────────────────────────────────────
# 32-byte URL-safe base64-encoded key. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PHI_ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# ── Telephony (Twilio) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WEBHOOK_URL=https://your-domain.com/webhooks/telephony

# ── Transcription (Deepgram) ──────────────────────────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key
TRANSCRIPTION_CALLBACK_URL=https://your-domain.com/webhooks/transcription/complete

# ── AI (Anthropic / Claude) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
CLASSIFICATION_MODEL=claude-sonnet-4-6

# ── CRM (hc1) ─────────────────────────────────────────────────────────────────
HC1_CRM_BASE_URL=https://your-hc1-instance.com/api
HC1_CRM_API_KEY=your-hc1-api-key
HC1_CRM_TIMEOUT_SECONDS=30
